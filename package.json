{
  "name": "Progressor",
  "private": true,
  "workspaces": ["client", "server"],
  "scripts": {
    "dev:client": "npm run dev -w client",
    "dev:server": "npm run dev -w server",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "npm run build -w client && npm run build -w server",
    "build:client": "npm run build -w client",
    "build:server": "npm run build -w server",
    "typecheck": "npm run typecheck -w server && npm run typecheck -w client",
    "typecheck:client": "npm run typecheck -w client",
    "typecheck:server": "npm run typecheck -w server",
    "migrate": "npm run migrate -w server",
    "validate": "npm run typecheck && npm run build",
    "validate:quick": "npm run typecheck"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}

