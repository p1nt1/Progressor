# ── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/Progressor

# ── Google OAuth 2.0 ─────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ── OpenAI ───────────────────────────────────────────────
# Required for AI workout generation & coaching features
# Leave empty to disable AI features gracefully
OPENAI_API_KEY=

# ── Server ───────────────────────────────────────────────
PORT=4000
NODE_ENV=development
SESSION_SECRET=change-me-to-a-random-string-at-least-32-chars
CLIENT_URL=http://localhost:5173

# ── Client (Vite) ───────────────────────────────────────
# Leave empty for local dev (Vite proxy handles /api)
VITE_API_URL=

# ── Netlify (set in Netlify dashboard, not needed locally) ──
# Used by netlify.toml to proxy /api/* requests to the backend
RAILWAY_API_URL=https://your-app.up.railway.app

